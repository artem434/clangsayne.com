<header class="header cf" role="banner">
  <a class="logo" href="/index.html">
    <h1{% if title == "Home" %} class="home_logo_h1"{% endif %}>Clang Sayne</h1>
  </a>

  <div class="social">
    <ul>
      {% for item in site.socials %}
      <li>
        <a href="{{ item.href }}"{% if item.external %} target="_blank"{% endif %}>
          <img src="/assets/images/social/{{ item.icon }}" width="50" height="50" alt="{{ item.alt }}">
        </a>
      </li>
      {% endfor %}
    </ul>
  </div>

  <nav role="navigation">
    <ul class="menu full_menu cf">
      {% for item in site.nav %}
      <li>
        {% set u = page.url %}
        {% set active = (u == item.href) or (u == item.href + '/') or (item.href == '/index.html' and (u == '/' or u == '/index.html' or u == '/index.html/')) %}
        <a href="{{ item.href }}"{% if active %} class="active"{% endif %}>{{ item.label }}</a>
      </li>
      {% endfor %}
    </ul>

    <button type="button" id="burger" class="burger" aria-label="Open menu" aria-expanded="false">
      <span class="burgerline"></span>
      <span class="burgerline"></span>
      <span class="burgerline"></span>
    </button>
  </nav>
</header>
